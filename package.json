import { useState, useEffect, useCallback } from "react";
import { useNavigate } from "react-router-dom";
import { motion } from "framer-motion";
import { User, Heart, Inbox, LogOut, Save, ShoppingCart } from "lucide-react";
import { toast } from "sonner";
import { api, formatApiErrorDetail } from "../lib/api";
import { useAuth } from "../context/AuthContext";
import { PCCard } from "../components/PCCard";
import { formatPrice } from "../lib/whatsapp";

export default function Account() {
  const { user, logout, updateProfile } = useAuth();
  const navigate = useNavigate();
  const [tab, setTab] = useState("profile");
  const [name, setName] = useState(user?.name || "");
  const [savingName, setSavingName] = useState(false);
  const [wishlist, setWishlist] = useState([]);
  const [inquiries, setInquiries] = useState([]);

  useEffect(() => {
    setName(user?.name || "");
  }, [user]);

  const loadWishlist = useCallback(() => {
    api.get("/customer/wishlist").then((r) => setWishlist(r.data)).catch(() => {});
  }, []);

  useEffect(() => {
    loadWishlist();
  }, [loadWishlist, user?.wishlist?.length]);

  useEffect(() => {
    if (tab === "inquiries") {
      api.get("/customer/inquiries").then((r) => setInquiries(r.data)).catch(() => {});
    }
  }, [tab]);

  const saveName = async () => {
    setSavingName(true);
    try {
      await updateProfile(name);
      toast.success("Profile updated");
    } catch (err) {
      toast.error(formatApiErrorDetail(err.response?.data?.detail));
    } finally {
      setSavingName(false);
    }
  };

  const handleLogout = async () => {
    await logout();
    navigate("/");
  };

  const tabs = [
    { id: "profile", label: "Profile", icon: User },
    { id: "wishlist", label: "Wishlist", icon: Heart },
    { id: "inquiries", label: "My Inquiries", icon: Inbox },
  ];

  return (
    <div data-testid="account-page">
      <section className="border-b border-white/10 py-16 relative overflow-hidden">
        <div className="absolute inset-0 grid-bg opacity-30" />
        <div className="relative max-w-7xl mx-auto px-6 lg:px-8 flex items-center gap-5">
          {user?.picture ? (
            <img src={user.picture} alt="" className="w-16 h-16 rounded-full border-2 border-neon-cyan object-cover" />
          ) : (
            <div className="w-16 h-16 rounded-full bg-neon-cyan/10 border-2 border-neon-cyan flex items-center justify-center">
              <User className="w-7 h-7 text-neon-cyan" />
            </div>
          )}
          <div>
            <span className="overline">My Account</span>
            <h1 className="font-heading font-black uppercase text-3xl lg:text-4xl tracking-tight">{user?.name}</h1>
            <p className="text-zinc-500 text-sm">{user?.email}</p>
          </div>
        </div>
      </section>

      <section className="py-10">
        <div className="max-w-7xl mx-auto px-6 lg:px-8">
          <div className="flex gap-2 mb-8 border-b border-white/10 flex-wrap">
            {tabs.map((t) => (
              <button
                key={t.id}
                onClick={() => setTab(t.id)}
                data-testid={`account-tab-${t.id}`}
                className={`flex items-center gap-2 px-5 py-3 text-xs uppercase tracking-widest font-heading font-bold border-b-2 -mb-px transition-colors ${
                  tab === t.id ? "border-neon-cyan text-neon-cyan" : "border-transparent text-zinc-500 hover:text-white"
                }`}
              >
                <t.icon className="w-4 h-4" /> {t.label}
                {t.id === "wishlist" && wishlist.length > 0 && (
                  <span className="ml-1 text-neon-cyan">({wishlist.length})</span>
                )}
              </button>
            ))}
          </div>

          {tab === "profile" && (
            <div className="max-w-lg" data-testid="profile-tab">
              <div className="space-y-5">
                <div>
                  <label className="block text-xs uppercase tracking-widest text-zinc-500 mb-2">Display Name</label>
                  <input value={name} onChange={(e) => setName(e.target.value)} data-testid="profile-name-input"
                    className="w-full bg-black border border-white/15 px-4 py-3 text-white font-mono text-sm focus:border-neon-cyan focus:outline-none" />
                </div>
                <div>
                  <label className="block text-xs uppercase tracking-widest text-zinc-500 mb-2">Email</label>
                  <input value={user?.email || ""} disabled
                    className="w-full bg-black/50 border border-white/10 px-4 py-3 text-zinc-500 font-mono text-sm" />
                </div>
                <div className="flex items-center gap-3">
                  <span className="text-xs uppercase tracking-widest text-zinc-500">Sign-in method:</span>
                  <span className="text-xs uppercase tracking-widest text-neon-cyan border border-neon-cyan/30 px-2 py-1">
                    {user?.auth_provider === "google" ? "Google" : "Email"}
                  </span>
                </div>
                <div className="flex gap-3 pt-2">
                  <button onClick={saveName} disabled={savingName} data-testid="save-profile-btn" className="btn-primary">
                    <Save className="w-4 h-4" /> {savingName ? "Saving..." : "Save"}
                  </button>
                  <button onClick={handleLogout} data-testid="account-logout-btn" className="btn-secondary">
                    <LogOut className="w-4 h-4" /> Logout
                  </button>
                </div>
              </div>
            </div>
          )}

          {tab === "wishlist" && (
            <div data-testid="wishlist-tab">
              {wishlist.length === 0 ? (
                <div className="text-center py-20 text-zinc-500">
                  <Heart className="w-12 h-12 mx-auto mb-4 opacity-30" />
                  <p>No saved builds yet. Tap the heart on any PC to save it here.</p>
                  <button onClick={() => navigate("/shop")} className="btn-primary mt-6 inline-flex">Browse Builds</button>
                </div>
              ) : (
                <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                  {wishlist.map((p, i) => (
                    <PCCard key={p.slug} product={p} index={i} />
                  ))}
                </div>
              )}
            </div>
          )}

          {tab === "inquiries" && (
            <div data-testid="inquiries-tab">
              {inquiries.length === 0 ? (
                <div className="text-center py-20 text-zinc-500">
                  <Inbox className="w-12 h-12 mx-auto mb-4 opacity-30" />
                  <p>No inquiries yet. Add builds to your inquiry and send them on WhatsApp.</p>
                </div>
              ) : (
                <div className="space-y-4">
                  {inquiries.map((inq, idx) => (
                    <motion.div
                      key={inq.id || idx}
                      initial={{ opacity: 0, y: 10 }}
                      animate={{ opacity: 1, y: 0 }}
                      className="border border-white/10 bg-surface p-6"
                      data-testid={`my-inquiry-${idx}`}
                    >
                      <div className="flex items-center justify-between flex-wrap gap-2 mb-4">
                        <span className="flex items-center gap-2 font-heading font-bold uppercase text-sm">
                          <ShoppingCart className="w-4 h-4 text-neon-cyan" /> {inq.items?.length} Build(s)
                        </span>
                        <span className="text-xs text-zinc-500">{new Date(inq.created_at).toLocaleString("en-IN")}</span>
                      </div>
                      <div className="space-y-2">
                        {inq.items?.map((it, k) => (
                          <div key={k} className="flex justify-between text-sm border-b border-white/5 pb-2">
                            <span className="text-zinc-300">{it.name}</span>
                            <span className="text-neon-cyan font-bold">{formatPrice(it.price)}</span>
                          </div>
                        ))}
                      </div>
                      <div className="flex justify-between mt-4 pt-2">
                        <span className="text-xs uppercase tracking-widest text-zinc-500">Est. Total</span>
                        <span className="font-heading font-black text-lg">{formatPrice(inq.total)}</span>
                      </div>
                    </motion.div>
                  ))}
                </div>
              )}
            </div>
          )}
        </div>
      </section>
    </div>
  );
}
